class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int n = nums.size();
        int current_count = 0;
        int max_count = nums[0];

        for(int i = 0; i<n; i++){
            if(current_count < 0){
                current_count = 0;
            }
            current_count += nums[i];
            max_count = max(current_count, max_count);

        }

        return max_count;

    }
};
