class Solution {
public:
    char findTheDifference(string s, string t) {
        unordered_map<char, int> freq;

        for(int i = 0; i < s.size(); i++){
            freq[s[i]]++;
        }

        for(int i = 0; i < t.size(); i++){
            freq[t[i]]--;

            if(freq[t[i]] < 0){
                return t[i];
            }
        }

        return ' ';
    }
};
