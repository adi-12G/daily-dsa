class Solution {
public:
    void rotate(vector<int>& nums, int k) {
        int n = nums.size();
        vector<int> temp(n);

        for(int i = 0; i<n; i++){
        int old_index = i;
        int new_index = (old_index + k) %n;
         temp[new_index] = nums[i];
        }

        for(int i = 0; i<n; i++){
            nums[i] = temp[i];
            
        } 
    }
};
