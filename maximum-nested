class Solution {
public:
    int maxDepth(string s) {
        int n = s.length();
        int depth = 0;
        int maxi = 0;
        for(int i = 0; i<n; i++){
          if(s[i] == '('){
            depth++;
            maxi = max(maxi,depth);
          }
          else if(s[i] == ')'){
            depth--;
          }
        }

        return maxi;

    }
};
