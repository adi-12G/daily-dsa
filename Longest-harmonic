class Solution {
public:
    int findLHS(vector<int>& nums) {
        int n = nums.size();
        int ans = 0;
        unordered_map<int, int> freq;

        for(int i = 0;  i<n; i++){
            freq[nums[i]]++;
        }

        for(auto it : freq){
            int x = it.first;
        if(freq.count(x+1)){
            ans = max(ans, freq[x] + freq[x+1]);
    }
        }
        

        return ans;

    }
};
